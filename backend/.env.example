# SplitVPN backend — environment template.
# Copy to .env and fill in real values. All values below are safe placeholders.

# ---- PostgreSQL (used by docker-compose to init the db container) ----
POSTGRES_USER=splitvpn
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=splitvpn

# ---- Host port for the API (container always listens on 8000) ----
API_PORT=8080

# ---- App runtime ----
DEBUG=false

# Inside docker-compose these are derived from POSTGRES_* / the cache service and
# do not need to be set. Override them only when running the app outside compose.
# DATABASE_URL=postgresql+asyncpg://splitvpn:change-me-strong-password@db:5432/splitvpn
# REDIS_URL=redis://cache:6379/0

# ---- JWT (auth layer is currently disabled; kept for when it is restored) ----
JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Blocked-domain sources (defaults are sensible; override to self-host) ----
# DOMAINS_PRIMARY_URL=https://antizapret.prostovpn.org/domains-export.txt
# DOMAINS_FALLBACK_URL=https://raw.githubusercontent.com/zapret-info/z-i/master/domains.txt
# DOMAINS_UPDATE_INTERVAL_HOURS=6

# ---- sing-box CLI used to compile binary .srs rule-sets ----
# Must match the libbox version embedded in the apps.
# SING_BOX_BIN=/usr/local/bin/sing-box

# ---- IP rule-set (Telegram MTProto CIDRs, services without SNI) ----
# TELEGRAM_CIDR_URL=https://core.telegram.org/resources/cidr.txt
# IP_RULESET_UPDATE_INTERVAL_HOURS=24

# ---- Proxy health checker ----
# PROXY_CHECK_INTERVAL_MINUTES=5
# PROXY_CHECK_TIMEOUT_SECONDS=5

# NOTE: proxy-node credentials (host, VLESS uuid, Reality keys) live in the
# database, seeded via `python -m scripts.seed_proxy`, NOT in this file.
